# ── Firebase (same project as novaura.life) ──────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=          # Required for WebRTC voice signaling (Realtime DB)

# ── OpenRouter (primary AI gateway — routes to free models by default) ───────
VITE_OPENROUTER_KEY=sk-or-...           # Platform key — covers all staff by default
OPENROUTER_API_KEY=sk-or-...           # Same key, used by Rust backend for inference
OPENROUTER_MANAGER_KEY=sk-or-...       # Provisioning key — creates/revokes/limits keys per tier (Rust only)

# ── AI Keys (used by Rust backend — never exposed to frontend) ────────────────
# Set these as environment variables before running `tauri dev` / `tauri build`
ANTHROPIC_API_KEY=                   # Claude — claude-sonnet-4-6 default
GEMINI_API_KEY=                      # Gemini — gemini-2.0-flash default
ALIBABA_API_KEY=                     # Kimi K2 via AI/ML API gateway

# ── Optional ─────────────────────────────────────────────────────────────────
VITE_BACKEND_URL=https://novaura.life/api   # NovAura platform API base
