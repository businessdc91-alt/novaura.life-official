# NovAura Firebase Functions — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── Firebase Admin SDK ─────────────────────────────────────────────────────
# Download service account key from Firebase Console → Project Settings → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account.json

# ─── AI Provider API Keys ───────────────────────────────────────────────────
# At least ONE provider must be configured for the AI to work.
# We recommend OpenRouter as primary + Gemini as fallback.

# OpenRouter (Primary — 1500+ models, recommended)
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini (Fallback)
GEMINI_API_KEY=AIza...
GEMINI_API_KEY_BACKUP=AIza...

# Kimi / Moonshot (Chinese LLM, OpenAI-compatible)
KIMI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Azure OpenAI / Azure AI Foundry
AZURE_OPENAI_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Alibaba Cloud (Qwen models)
ALIBABA_API_KEY=sk-...
ALIBABA_ACCESS_KEY_ID=LTAI...
ALIBABA_ACCESS_KEY_SECRET=...

# AWS Bedrock / Nova
AWS_NOVA_API_KEY=...

# Other providers
HUGGINGFACE_API_KEY=hf_...
NOVITA_API_KEY=...
SCALEWAY_API_KEY=...
HYPERBOLIC_API_KEY=...
FIREWORKS_API_KEY=...

# ─── Email (name.com SMTP) ──────────────────────────────────────────────────
# Your name.com email SMTP credentials
SMTP_HOST=smtp.name.com
SMTP_PORT=587
SMTP_USER=your-email@novaura.life
SMTP_PASS=your-email-password-or-app-password

# ─── Stripe (Payments) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Domain Registrar (name.com) ────────────────────────────────────────────
NAMECOM_USERNAME=your-namecom-user
NAMECOM_API_TOKEN=your-namecom-token

# ─── Encryption Secrets ─────────────────────────────────────────────────────
# Generate strong random strings for these (e.g. `openssl rand -hex 32`)
VAULT_ENCRYPTION_SECRET=your-32-byte-hex-secret
USER_KEY_ENCRYPTION_SECRET=your-32-byte-hex-secret
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# ─── Backend URL ────────────────────────────────────────────────────────────
BACKEND_URL=https://us-central1-novaura-life.cloudfunctions.net/api
