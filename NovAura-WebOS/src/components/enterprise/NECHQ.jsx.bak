                              </Badge>
                              <Badge className="bg-blue-500/10 text-blue-400 border-blue-500/20">
                                {skimMeta.breakdown.redeployable} Redeployable
                              </Badge>
                              <Badge className="bg-amber-500/10 text-amber-400 border-amber-500/20">
