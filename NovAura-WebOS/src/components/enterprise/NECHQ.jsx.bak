          <div className="mt-auto space-y-4">
            <Card className="bg-gradient-to-br from-primary/10 to-purple-500/10 border-primary/20 p-4">
              <p className="text-xs font-bold mb-2">NECHQ Security</p>
              <div className="flex items-center gap-2 mb-3">
                <div className="w-2 h-2 rounded-full bg-green-400" />
