                             <div className="p-2 rounded-lg bg-white/5 border border-white/5 flex items-center gap-2 cursor-pointer hover:bg-white/10 transition-all">
                                <Cpu className="w-3.5 h-3.5 text-primary" />
                                <span className="text-[10px] truncate">Project-X_Enhanced.os</span>
            )}

            {activeTab === 'assets' && (
