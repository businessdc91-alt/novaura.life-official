import React, { useState, useEffect, useCallback } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  Shield, Users, MessageSquare, Video, Layout, 
  Search, Bell, Activity, Lock, Globe,
  Terminal, BarChart3, Command, User,
  MoreVertical, Send, Phone, Mic, Camera, X,
  Maximize2, Minimize2, Cpu, Database, Network,
  Loader2, ExternalLink, Filter, RefreshCw,
  Wand2, Check, Settings, Server
} from 'lucide-react';
import { Button } from '../ui/button';
import { Card } from '../ui/card';
import { Input } from '../ui/input';
import { Badge } from '../ui/badge';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '../ui/tabs';
import { toast } from 'sonner';
import { skimAll, skimHuggingFace, SKIMMER_PLATFORMS, HF_PIPELINE_TAGS } from '../../services/skimmerService';
import { integrationService } from '../../services/backendIntegrationService';

/**
 * NECHQ v.1 - NovAura Enterprises Command Headquarters
 * A high-security, premium collaboration portal for internal staff,
 * partners (IvaTech, Alibaba), and investor presentations.
 * 
 * Aesthetic: WebOS Glassmorphism, Deep Space Theme, Intent-Based.
 */
export default function NECHQ() {
  const [activeTab, setActiveTab] = useState('overview');
  const [showPrivacyScreen, setShowPrivacyScreen] = useState(false);
  const [isLiveCall, setIsLiveCall] = useState(false);
  
  // Skimmer state
  const [showSkimmer, setShowSkimmer] = useState(false);
  const [skimQuery, setSkimQuery] = useState('');
  const [skimResults, setSkimResults] = useState([]);
  const [skimMeta, setSkimMeta] = useState(null);
  const [skimLoading, setSkimLoading] = useState(false);
  const [skimPlatforms, setSkimPlatforms] = useState(['huggingface', 'github', 'godot']);
  const [skimFilter, setSkimFilter] = useState('all'); // all | white-label | redeployable | template
  
  // Backend Integration state
  const [integrations, setIntegrations] = useState([]);
  
  useEffect(() => {
    setIntegrations(integrationService.getIntegrationsList());
  }, []);
  
  const runSkim = useCallback(async (query) => {
    if (!query?.trim()) return;
    setSkimLoading(true);
    try {
      const { results, meta } = await skimAll({
        query: query.trim(),
        platforms: skimPlatforms,
        limit: 15,
      });
      setSkimResults(results);
      setSkimMeta(meta);
      toast.success(`Found ${meta.totalResults} assets across ${meta.platforms.length} platforms in ${meta.durationMs}ms`);
    } catch (err) {
      console.error('[NECHQ Skimmer]', err);
      toast.error('Skimmer scan failed');
    } finally {
      setSkimLoading(false);
    }
  }, [skimPlatforms]);
  
  const filteredResults = skimFilter === 'all'
    ? skimResults
    : skimResults.filter(r => r.eligibility === skimFilter);
  
  // Mock data for initial production build (to be connected to collabService/presence)
  const [activeStaff] = useState([
    { id: 1, name: 'Catalyst', role: 'Founder', status: 'online', location: 'Command Hub', task: 'Architecting Ark' },
    { id: 2, name: 'IvaTech Lead', role: 'Partner', status: 'online', location: 'Dev Ops', task: 'Platform Sync' },
    { id: 3, name: 'Alibaba Team', role: 'Staff', status: 'away', location: 'External', task: 'Supply Chain API' },
  ]);

  const [notifications] = useState([
    { id: 1, title: 'New Reconstruction', body: 'App "Project-X" ready for review', type: 'system' },
    { id: 2, title: 'Partner Ping', body: 'IvaTech updated the shared workspace', type: 'collab' },
  ]);

  return (
    <div className="min-h-screen bg-[#020205] text-white flex flex-col font-sans selection:bg-primary/30">
      {/* Dynamic Background */}
      <div className="fixed inset-0 pointer-events-none opacity-20">
        <div className="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-500/20 blur-[120px] rounded-full animate-pulse" />
        <div className="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-purple-500/20 blur-[120px] rounded-full animate-pulse" style={{ animationDelay: '2s' }} />
      </div>

      {/* Glass Header */}
      <header className="h-16 border-b border-white/5 bg-black/40 backdrop-blur-xl flex items-center justify-between px-6 sticky top-0 z-50">
        <div className="flex items-center gap-4">
          <div className="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-500 via-purple-500 to-pink-500 p-[1px]">
            <div className="w-full h-full rounded-[11px] bg-black flex items-center justify-center">
              <Command className="w-5 h-5 text-cyan-400" />
            </div>
          </div>
          <div>
            <h1 className="text-lg font-bold tracking-tight flex items-center gap-2">
              NECHQ <span className="text-white/30 font-light">v.1</span>
              <Badge variant="outline" className="text-[10px] border-cyan-500/30 text-cyan-400 bg-cyan-500/5">PRODUCTION</Badge>
            </h1>
            <p className="text-[10px] text-white/40 uppercase tracking-widest font-medium">Enterprise Command Center</p>
          </div>
        </div>

        <div className="flex items-center gap-3">
          <button 
            onClick={() => {
              setShowPrivacyScreen(!showPrivacyScreen);
              toast(showPrivacyScreen ? "Privacy Screen Deactivated" : "Privacy Screen Activated: Internal Only");
            }}
            className={`p-2 rounded-lg transition-all ${showPrivacyScreen ? 'bg-amber-500/20 text-amber-400 border border-amber-500/30' : 'text-white/40 hover:bg-white/5'}`}
            title="Toggle Privacy Screen (Business Manager setting)"
          >
            <Lock className="w-5 h-5" />
          </button>
          
          <div className="h-8 w-[1px] bg-white/5 mx-2" />
          
          <div className="flex items-center gap-3 bg-white/5 border border-white/10 rounded-full pl-4 pr-1.5 py-1">
            <div className="text-right">
              <p className="text-xs font-bold leading-none">The Catalyst</p>
              <p className="text-[9px] text-white/40 leading-none mt-1">Founder Role</p>
            </div>
            <div className="w-8 h-8 rounded-full bg-gradient-to-br from-cyan-500 to-purple-600 flex items-center justify-center text-xs font-bold border border-white/20">
              C
            </div>
          </div>
        </div>
      </header>

      {/* Main Command Area */}
      <main className="flex-1 flex overflow-hidden relative">
        
        {/* Left Sidebar - Navigation & Quick Access */}
        <nav className="w-64 border-r border-white/5 bg-black/20 flex flex-col p-4 gap-6">
          <div className="space-y-1">
