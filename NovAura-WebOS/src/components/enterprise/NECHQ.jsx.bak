                  )}
                </AnimatePresence>
              </motion.div>
            )}

            {activeTab === 'infrastructure' && (
              <motion.div initial={{ opacity: 0, scale: 0.98 }} animate={{ opacity: 1, scale: 1 }} className="h-full flex flex-col">
                <div className="flex items-center justify-between mb-6">
                  <div>
                    <h2 className="text-2xl font-bold tracking-tight">Cloud Infrastructure</h2>
                    <p className="text-sm text-white/40 mt-1">Manage global deployments, compute resources, and the Staff Toolbox.</p>
                  </div>
                  <div className="flex gap-2">
                    <Badge className="bg-green-500/10 text-green-400 border-green-500/20 px-3 py-1">ALL SYSTEMS OPERATIONAL</Badge>
                  </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                  {/* Toolbox Section */}
                  <Card className="col-span-1 bg-white/5 border-white/10 overflow-hidden flex flex-col">
                    <div className="p-4 border-b border-white/10 bg-white/[0.02]">
                      <h3 className="text-sm font-bold flex items-center gap-2 text-cyan-400">
                        <Wand2 className="w-4 h-4" />
                        Staff Toolbox
                      </h3>
                    </div>
                    <div className="p-4 space-y-3 flex-1">
                      {[
                        { name: 'OpenRouter (Testing)', icon: 'ðŸ”€', desc: 'Free inference: Llama, Mistral, Gemma', owned: true },
                        { name: 'Gemini 3.1 Pro', icon: 'âœ¨', desc: 'High-IQ code assistance', owned: true },
                        { name: 'Ollama Local', icon: 'ðŸ¦™', desc: 'Private inference stage', owned: false },
                        { name: 'LM Studio', icon: 'ðŸ–¥ï¸', desc: 'Local GGUF model runner', owned: false },
                        { name: 'Vertex AI', icon: 'â˜ï¸', desc: 'Enterprise cloud inference', owned: false },
                      ].map((tool, i) => (
                        <div key={i} className="flex items-center justify-between p-3 rounded-xl bg-black/20 border border-white/5 group hover:border-cyan-500/30 transition-all">
                          <div className="flex items-center gap-3">
                            <span className="text-xl">{tool.icon}</span>
                            <div>
                              <p className="text-xs font-bold">{tool.name}</p>
                              <p className="text-[9px] text-white/30">{tool.desc}</p>
                            </div>
                          </div>
                          {tool.owned ? (
                            <div className="w-6 h-6 rounded-full bg-cyan-500/20 flex items-center justify-center">
                              <Check className="w-3.5 h-3.5 text-cyan-400" />
                            </div>
                          ) : (
                            <button className="text-[9px] font-bold text-cyan-500 hover:underline uppercase tracking-tighter">Enable</button>
                          )}
                        </div>
                      ))}
                    </div>
                    <div className="p-4 bg-cyan-500/5 border-t border-cyan-500/10">
                      <p className="text-[10px] text-cyan-400/60 leading-relaxed italic">
                        "Set your OpenRouter API key in Settings to enable free-tier inference."
                      </p>
                    </div>
                  </Card>

                  {/* Resource Monitoring */}
                  <Card className="col-span-2 bg-white/5 border-white/10 p-6 flex flex-col">
                    <div className="flex items-center justify-between mb-8">
                      <h3 className="text-lg font-bold">System Load & Deployment Nodes</h3>
                      <div className="flex gap-4">
                        <div className="text-center">
                          <p className="text-[9px] text-white/30 uppercase font-bold mb-1">Global Traffic</p>
                          <p className="text-sm font-bold text-primary">2.4m req/s</p>
                        </div>
                        <div className="text-center border-l border-white/10 pl-4">
                          <p className="text-[9px] text-white/30 uppercase font-bold mb-1">Compute Cost</p>
                          <p className="text-sm font-bold text-green-400">$0.04/hr</p>
                        </div>
                      </div>
                    </div>
                    <div className="flex-1 grid grid-cols-2 gap-6">
                      <div className="space-y-6">
                        {[
                          { label: 'Edge Capacity', val: '92%', color: 'from-cyan-500 to-blue-500' },
                          { label: 'Database IOPS', val: '45%', color: 'from-purple-500 to-pink-500' },
                          { label: 'AI Inference Pool', val: '14%', color: 'from-green-500 to-emerald-500' },
                        ].map((m, i) => (
                          <div key={i} className="space-y-2">
                            <div className="flex justify-between text-[10px] font-bold text-white/40 uppercase">
                              <span>{m.label}</span>
                              <span className="text-white/80">{m.val}</span>
                            </div>
                            <div className="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                              <motion.div initial={{ width: 0 }} animate={{ width: m.val }} className={`h-full bg-gradient-to-r ${m.color}`} />
                            </div>
                          </div>
                        ))}
                      </div>
                      <div className="bg-black/40 rounded-2xl border border-white/5 p-4 flex flex-col">
                        <p className="text-[10px] font-bold text-white/20 uppercase tracking-widest mb-4">Active Deployment Map</p>
                        <div className="flex-1 relative min-h-[120px]">
                          <div className="absolute top-1/4 left-1/4 w-3 h-3 bg-cyan-400 rounded-full animate-ping" />
                          <div className="absolute top-1/4 left-1/4 w-3 h-3 bg-cyan-500 rounded-full shadow-[0_0_10px_cyan]" />
                          <div className="absolute top-1/2 left-3/4 w-2 h-2 bg-purple-400 rounded-full animate-ping" />
                          <div className="absolute top-1/2 left-3/4 w-2 h-2 bg-purple-500 rounded-full" />
                          <div className="absolute bottom-1/3 left-1/2 w-2 h-2 bg-primary rounded-full animate-ping" />
                          <div className="absolute bottom-1/3 left-1/2 w-2 h-2 bg-primary rounded-full" />
                          <div className="absolute inset-0 flex items-center justify-center">
                            <Globe className="w-24 h-24 text-white/5" />
                          </div>
                        </div>
                        <p className="text-[9px] text-white/20 text-center mt-4">Optimized for low-latency partner access (IvaTech/Alibaba)</p>
                      </div>
                    </div>
                  </Card>
                </div>

                {/* Backend Integration Station */}
                <div className="mt-6">
                  <Card className="bg-gradient-to-br from-indigo-500/10 to-purple-500/10 border-indigo-500/20 p-6">
                    <div className="flex items-center justify-between mb-6">
                      <div>
                        <h3 className="text-lg font-bold flex items-center gap-2">
                          <Server className="w-5 h-5 text-indigo-400" />
                          Backend Integration Station
                        </h3>
                        <p className="text-[10px] text-white/40 mt-1">Unified auto-provisioning for external services, domains, and AI models.</p>
                      </div>
                      <Button size="sm" variant="outline" className="text-[10px] h-8 border-indigo-500/30 text-indigo-400">
                        + Add Provider
                      </Button>
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                      {integrations.map((provider) => (
                        <div key={provider.id} className="p-4 rounded-xl bg-black/40 border border-white/5 hover:border-indigo-500/30 transition-all flex flex-col justify-between">
                          <div>
                            <div className="flex justify-between items-start mb-2">
                              <div className="flex items-center gap-2">
                                <span className="text-xl">{provider.icon}</span>
                                <h4 className="font-bold text-sm">{provider.name}</h4>
                              </div>
                              <Badge className={`text-[8px] h-4 px-1.5 ${
                                provider.status === 'ready' ? 'bg-green-500/10 text-green-400 border-green-500/20' : 'bg-amber-500/10 text-amber-400 border-amber-500/20'
                              }`}>
                                {provider.status.toUpperCase()}
                              </Badge>
                            </div>
                            <p className="text-[10px] text-white/40 mb-4 h-8">{provider.description}</p>
                          </div>
                          <div className="flex justify-between items-center mt-2 pt-3 border-t border-white/5">
                            <span className="text-[9px] text-white/20 uppercase tracking-widest">{provider.category}</span>
                            {provider.configured ? (
                              <span className="text-[10px] text-cyan-400 font-bold flex items-center gap-1"><Check className="w-3 h-3" /> Connected</span>
                            ) : (
                              <Button size="sm" className="text-[9px] h-6 px-3 bg-white/10 hover:bg-white/20 text-white border border-white/10">
                                Configure
                              </Button>
                            )}
                          </div>
                        </div>
                      ))}
                    </div>
                  </Card>
                </div>
              </motion.div>
            )}

          </div>
        </section>
      </main>
      {/* Floating Privacy Indicator */}
      <AnimatePresence>
        {showPrivacyScreen && (
          <motion.div
            initial={{ opacity: 0, y: 50 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: 50 }}
            className="fixed bottom-6 right-6 bg-amber-500/90 text-black font-bold px-6 py-3 rounded-2xl shadow-[0_0_40px_rgba(245,158,11,0.4)] z-[100] flex items-center gap-3 backdrop-blur-md"
          >
            <Shield className="w-5 h-5 animate-pulse" />
            <span>PRIVACY MODE ACTIVE: BUSINESS MANAGER ONLY</span>
            <button onClick={() => setShowPrivacyScreen(false)} className="ml-2 p-1 hover:bg-black/10 rounded-lg"><X className="w-4 h-4" /></button>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}


