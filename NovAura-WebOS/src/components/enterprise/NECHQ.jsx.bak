                            <p className="text-[10px] mt-1 text-white/10">Try: "chat app", "image generation", "game engine", "text-to-speech"</p>
                          </div>
                        )}

                        {skimMeta && (
                          <div className="mt-3 pt-3 border-t border-white/5 flex items-center justify-between text-[9px] text-white/20">
                            <span>{skimMeta.totalResults} results across {skimMeta.platforms.join(', ')} in {skimMeta.durationMs}ms</span>
                            <button onClick={() => runSkim(skimQuery)} className="flex items-center gap-1 hover:text-white/40 transition-colors">
