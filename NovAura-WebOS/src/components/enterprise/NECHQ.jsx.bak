                                        : asset.eligibility === 'template' ? 'bg-amber-500/10 text-amber-400 border-amber-500/20'
                                        : 'bg-white/5 text-white/30 border-white/10'
                                      }`}>
                                        {asset.eligibility}
                                      </Badge>
                                    </div>
                                    <p className="text-[9px] text-white/30 truncate mt-0.5">{asset.author} â€¢ {asset.license} â€¢ â­{asset.stars} â€¢ â†“{asset.downloads}</p>
                                    <p className="text-[9px] text-white/20 truncate">{asset.description?.slice(0, 80)}</p>
                                  </div>
                                </div>
                                <div className="flex gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 ml-2">
                                  <a href={asset.url} target="_blank" rel="noopener noreferrer">
