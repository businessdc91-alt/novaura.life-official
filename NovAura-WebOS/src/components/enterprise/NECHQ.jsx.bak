                                  <div className="w-10 h-10 rounded-lg bg-black/40 flex items-center justify-center border border-white/10 text-lg flex-shrink-0">
                                    {asset.platform === 'huggingface' ? 'ðŸ¤—' 
                                      : asset.platform === 'github' ? 'ðŸ™'
                                      : asset.platform === 'godot' ? 'ðŸŽ®'
                                      : asset.platform === 'itch.io' ? 'ðŸ•¹ï¸'
                                      : 'ðŸ”'}
                                  </div>
                                  <div className="min-w-0 flex-1">
                                    <div className="flex items-center gap-2">
