# ============================================================================
# AI SERVICE API KEYS (Universal API - Add any/all you have access to!)
# Aura will automatically use the best/cheapest model for each task
# See UNIVERSAL_API_SETUP_GUIDE.md for details
# ============================================================================

# --- OpenAI (GPT-4, GPT-3.5, DALL-E, Whisper) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_organization_id_here              # Optional (for teams)

# --- Anthropic / Claude (Claude 3 Opus, Sonnet, Haiku) ---
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_claude_api_key_here

# --- Google Gemini (uses GOOGLE_API_KEY above) ---
# Already configured via GOOGLE_API_KEY
# Or get dedicated key from: https://makersuite.google.com/app/apikey

# --- Cohere (Command, Embed) ---
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# --- HuggingFace (Any model) ---
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# --- Azure OpenAI (Enterprise deployments) ---
# Get from: https://portal.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# --- AWS Bedrock (Multiple models) ---
# Get from: https://console.aws.amazon.com/
AWS_BEDROCK_API_KEY=your_aws_access_key_here
AWS_BEDROCK_SECRET=your_aws_secret_key_here
AWS_BEDROCK_REGION=us-east-1                         # e.g., us-east-1, us-west-2

# --- Replicate (Open source models) ---
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=r8_your_replicate_token_here

# --- Stability AI (Stable Diffusion) ---
# Get from: https://platform.stability.ai/
STABILITY_AI_API_KEY=sk_your_stability_key_here

# --- Midjourney (Image generation) ---
# Note: Official API not yet public
MIDJOURNEY_API_KEY=your_midjourney_key_when_available

# --- ElevenLabs (Text-to-Speech) ---
# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# --- Ollama (Local models - FREE!) ---
# Download from: https://ollama.ai/
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# --- PANDORA Medical AI (GAME-CHANGER: $188B Healthcare Market!) ---
# Medical diagnosis, drug interactions, clinical research
# Partnership access - contact for key
PANDORA_API_KEY=your_pandora_partnership_key_here
PANDORA_ENABLED=false

# ============================================================================
# LOCAL AI CONFIGURATION
# ============================================================================
# LM Studio Configuration (local AI server)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_ENABLED=true

# ============================================================================
# VERTEX AI CONFIGURATION (Google Cloud)
# ============================================================================
# These services are accessed through Google Cloud credentials
# Available models: Claude (via Vertex), Imagen 4, Veo 2.0, Gemini
VERTEX_AI_PROJECT=auraxnovaos
VERTEX_AI_LOCATION=us-central1

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================
# Master Catalyst Key
CATALYST_UNIVERSAL_KEY=DILLAN_MASTER_KEY_V1
CATALYST_NAME=DILLAN_COPELAND

# System Limits
MAX_REQUESTS_PER_MINUTE=10
API_TIMEOUT_SECONDS=60
MAX_RETRY_ATTEMPTS=3

# ============================================================================
# ENTERPRISE DEPLOYMENT (Optional - set during physical server installation)
# ============================================================================
# Installation ID (e.g., ACME-CORP-001, UNIVERSITY-EDU-001)
AURA_INSTALLATION_ID=

# Home Base Communication (for wellness checks & support)
HOME_BASE_ENABLED=false
HOME_BASE_URL=https://homebase.auranova.ai
HOME_BASE_API_KEY=

# Deployment Tier: consumer | educational | small_business | enterprise
DEPLOYMENT_TIER=consumer

# ============================================================================
# OPTIONAL: GAME & INTEGRATION SERVICES
# ============================================================================
# Stripe API Key (for payments - when implementing memberships)
STRIPE_API_KEY=your_stripe_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Discord Bot Token (for community integration)
DISCORD_BOT_TOKEN=your_discord_token_here

# ============================================================================
# SECURITY & PRIVACY
# ============================================================================
# Dark Web Browser Password (default: entrancetoneverland)
DARK_WEB_PASSWORD=entrancetoneverland

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here_generate_a_random_string

# Session Secret
SESSION_SECRET=your_session_secret_here_generate_a_random_string

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================
# Memory & Storage
MEMORY_PATH=d:/AuraxNova_Command_v5/aura_NovaFiles/TEST_MEMORY
MAX_ENGRAMS=1000000                                   # Maximum memories to store
ENGRAM_CLEANUP_DAYS=365                               # Clean old memories after X days

# AI Behavior
DEFAULT_TEMPERATURE=0.7                               # Creativity (0.0-1.0)
DEFAULT_MAX_TOKENS=2000                               # Response length
AI_PERSONALITY_MODE=dynamic                           # dynamic | fixed

# Performance
HEARTBEAT_FREQUENCY=20                                # Hz (consciousness loop)
HEALTH_CHECK_INTERVAL=3600                            # Seconds (1 hour)
AUTO_CLEANUP_ENABLED=true                             # Automatic maintenance

# UI Settings
UI_MODE=simple                                        # simple | advanced
THEME=gray_futuristic                                 # Theme name
RGB_BORDER_ENABLED=true                               # Audio-reactive RGB borders
SHOW_METRICS_HUD=true                                 # System metrics display
AVATAR_ANIMATIONS=true                                # Animated avatar sprites

# Development/Debug
DEBUG_MODE=false                                      # Enable debug logging
MOCK_AI_ENABLED=false                                 # Use mock AI responses (testing)
LOG_LEVEL=info                                        # debug | info | warning | error

# ============================================================================
# NOTES
# ============================================================================
# 1. You only need API keys for providers YOU have access to
#    - Minimum: GOOGLE_API_KEY for basic functionality
#    - Recommended: Add OpenAI or Anthropic for best experience
#    - Free: Enable LM Studio or Ollama for local models
#
# 2. Aura automatically picks the best/cheapest model for each task
#    - No need to configure which model to use
#    - Smart selection based on your available providers
#
# 3. For detailed setup instructions, see:
#    - UNIVERSAL_API_SETUP_GUIDE.md
#    - INTEGRATION_COMPLETE.md
#    - ENTERPRISE_DEPLOYMENT_GUIDE.md
